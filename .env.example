# Canonical site URL for metadata / Open Graph (use your production URL)
# NEXT_PUBLIC_SITE_URL=https://deafy.example.com

# Optional: absolute URL to the beta APK (overrides /beta/deafy-beta.apk)
# NEXT_PUBLIC_BETA_APK_URL=https://example.com/deafy-beta.apk

# deafy-backend (Nest) — used by app/api/register to proxy POST /auth/register
# Local:
# DEAFY_BACKEND_URL=http://127.0.0.1:3001
# Production:
# DEAFY_BACKEND_URL=https://api.your-domain.com

NEXT_PUBLIC_FIREBASE_API_KEY=XXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=XXXX
NEXT_PUBLIC_FIREBASE_PROJECT_ID=XXXX
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=XXXX
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=XXXX
NEXT_PUBLIC_FIREBASE_APP_ID=XXXX
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=XXXX